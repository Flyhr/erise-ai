# 废弃说明：
# 历史开发态 Dockerfile 已废弃。
# 现在统一使用 `erise-ai-backend/Dockerfile` 作为唯一官方镜像构建入口。

FROM maven:3.9.11-eclipse-temurin-21

WORKDIR /workspace

COPY settings.xml /root/.m2/settings.xml
COPY pom.xml ./
RUN mvn -q -DskipTests dependency:go-offline || true

CMD ["/bin/sh", "/workspace/docker/dev-entrypoint.sh"]
