APP_ENV=dev
MYSQL_DSN=mysql+pymysql://erise:erise_password@localhost:3306/erise_ai?charset=utf8mb4
REDIS_URL=redis://:redis_password@localhost:6379/0
INTERNAL_SERVICE_TOKEN=please-change-this-internal-api-key-to-a-long-random-value
JAVA_INTERNAL_BASE_URL=http://localhost:8080/internal/v1
JAVA_INTERNAL_API_KEY=please-change-this-internal-api-key-to-a-long-random-value
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEFAULT_MODEL_CODE=deepseek-chat
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=dev-qdrant-key
QDRANT_KB_COLLECTION=kb_chunks
QDRANT_TEMP_COLLECTION=temp_chunks
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_API_KEY=
EMBEDDING_VERSION=v1
EMBEDDING_DIMENSIONS=1536
# Leave blank to disable web search. When enabled, use the provider name only: tavily or duckduckgo.
WEB_SEARCH_PROVIDER=
WEB_SEARCH_MAX_RESULTS=5
# Required when WEB_SEARCH_PROVIDER=tavily
TAVILY_API_KEY=
