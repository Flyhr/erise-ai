FROM python:3.11-slim AS base

WORKDIR /workspace

# Install the system libraries required for PDF parsing and OCR flows.
RUN apt-get update && apt-get install -y --no-install-recommends \
    libxcb1 \
    libxext6 \
    libxrender1 \
    libsm6 \
    libice6 \
    libx11-6 \
    libxau6 \
    libxdmcp6 \
    poppler-utils \
    libmagic1 \
    libgomp1 \
    libglib2.0-0 \
    libgl1 \
    libglx-mesa0 \
    tesseract-ocr \
    tesseract-ocr-eng \
    tesseract-ocr-chi-sim \
    fonts-liberation \
    fonts-dejavu \
    && rm -rf /var/lib/apt/lists/*

ENV PYTHONUNBUFFERED=1
ENV PYTHONDONTWRITEBYTECODE=1

# Development dependencies are installed at image build time so container
# startup stays fast and reproducible.
COPY requirements.txt ./
RUN pip install --default-timeout=180 --no-cache-dir -r requirements.txt

CMD ["/bin/sh", "/workspace/docker/dev-entrypoint.sh"]
