FROM python:3.11-slim AS base

WORKDIR /workspace

# 安装 PDF/OCR 必需的系统依赖（解决 libxcb.so.1 报错）
RUN apt-get update && apt-get install -y --no-install-recommends \
    # 1. 核心图形库（解决 rapidocr/PyMuPDF 依赖的 libxcb）
    libxcb1 \
    libxext6 \
    libxrender1 \
    libsm6 \
    libice6 \
    libx11-6 \
    libxau6 \
    libxdmcp6 \
    # 2. PDF 处理辅助工具
    poppler-utils \
    # 3. OCR/图像处理依赖（适配 rapidocr_onnxruntime）
    libgomp1 \
    libglib2.0-0 \
    #用 libgl1 和 libglx-mesa0 
    libgl1 \
    libglx-mesa0 \
    # 4. 字体库（避免 OCR 时缺字体）
    fonts-liberation \
    fonts-dejavu \
    # 5. 清理缓存，减小镜像体积（必须做）
    && rm -rf /var/lib/apt/lists/*

ENV PYTHONUNBUFFERED=1
ENV PYTHONDONTWRITEBYTECODE=1

# 👇 安装 Python 依赖（放在系统依赖之后，利用 Docker 缓存）
COPY requirements.txt ./
RUN pip install --default-timeout=180 --no-cache-dir -r requirements.txt

CMD ["/bin/sh", "/workspace/docker/dev-entrypoint.sh"]