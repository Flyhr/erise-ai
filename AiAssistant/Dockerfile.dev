# 废弃说明：
# 历史开发态 Dockerfile 已废弃。
# 现在统一使用 `AiAssistant/Dockerfile` 作为唯一官方镜像构建入口。

FROM python:3.11-slim AS base

WORKDIR /workspace

ARG PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
ARG PIP_EXTRA_INDEX_URL=https://pypi.org/simple
ARG PIP_TRUSTED_HOST="pypi.tuna.tsinghua.edu.cn pypi.org files.pythonhosted.org"

# Install the system libraries required for PDF parsing and OCR flows.
RUN apt-get update && apt-get install -y --no-install-recommends \
    libxcb1 \
    libxext6 \
    libxrender1 \
    libsm6 \
    libice6 \
    libx11-6 \
    libxau6 \
    libxdmcp6 \
    poppler-utils \
    libmagic1 \
    libgomp1 \
    libglib2.0-0 \
    libgl1 \
    libglx-mesa0 \
    tesseract-ocr \
    tesseract-ocr-eng \
    tesseract-ocr-chi-sim \
    fonts-liberation \
    fonts-dejavu \
    && rm -rf /var/lib/apt/lists/*

ENV PYTHONUNBUFFERED=1
ENV PYTHONDONTWRITEBYTECODE=1
ENV PIP_DISABLE_PIP_VERSION_CHECK=1

# Development dependencies are installed at image build time so container
# startup stays fast and reproducible.
COPY requirements.txt ./
RUN /bin/sh -c 'set -eu; \
    pip_args="--default-timeout=180 --retries=8 --no-cache-dir"; \
    if [ -n "${PIP_INDEX_URL:-}" ]; then \
      pip_args="$pip_args --index-url ${PIP_INDEX_URL}"; \
    fi; \
    if [ -n "${PIP_EXTRA_INDEX_URL:-}" ]; then \
      pip_args="$pip_args --extra-index-url ${PIP_EXTRA_INDEX_URL}"; \
    fi; \
    for host in ${PIP_TRUSTED_HOST:-}; do \
      pip_args="$pip_args --trusted-host $host"; \
    done; \
    python -m pip install $pip_args -r requirements.txt'

CMD ["/bin/sh", "/workspace/docker/dev-entrypoint.sh"]
