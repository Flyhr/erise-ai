# 唯一官方环境配置示例
# 使用方式：
#   Copy-Item .env.example .env
#
# 说明：
# 1. 现在只保留 `.env` 这一套主配置
# 2. 历史 `.env.dev` / `.env.dev.example` 已废弃
# 3. 当前主链路以生产环境部署形态为基准：cloud -> LiteLLM -> DeepSeek / OpenAI / Ollama

COMPOSE_PROJECT_NAME=erise-ai
TZ=Asia/Shanghai
VITE_APP_TITLE=Erise-AI

MYSQL_DATABASE=erise_ai
MYSQL_USER=erise
MYSQL_PASSWORD=erise_password
MYSQL_ROOT_PASSWORD=root_password
MYSQL_HOST_PORT=3306

REDIS_PASSWORD=redis_password
REDIS_HOST_PORT=6379

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=erise-ai
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

QDRANT_HOST_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_API_KEY=dev-qdrant-key
QDRANT_KB_COLLECTION=kb_chunks
QDRANT_TEMP_COLLECTION=temp_chunks

JWT_SECRET=please-change-this-jwt-secret-at-least-32-chars
INTERNAL_API_KEY=please-change-this-internal-api-key-to-a-long-random-value
INTERNAL_SERVICE_TOKEN=please-change-this-internal-api-key-to-a-long-random-value
ACTION_CONFIRMATION_REQUIRED=true

JAVA_INTERNAL_BASE_URL=http://localhost:8080/internal/v1
JAVA_INTERNAL_API_KEY=please-change-this-internal-api-key-to-a-long-random-value

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini

DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

OLLAMA_API_KEY=
OLLAMA_BASE_URL=http://ollama:11434/v1
OLLAMA_CHAT_MODEL=qwen3:1.7b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_HOST_PORT=11434

LITELLM_API_KEY=
LITELLM_BASE_URL=http://litellm:4000/v1
LITELLM_MODEL=deepseek-chat

MODEL_PROVIDER=LITELLM
MODEL_BASE_URL=http://litellm:4000/v1
MODEL_API_KEY=
DEFAULT_MODEL_CODE=deepseek-chat

EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_PROVIDER_CODE=LITELLM
EMBED_BASE_URL=http://litellm:4000/v1
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_API_KEY=
EMBEDDING_VERSION=v1
EMBEDDING_DIMENSIONS=768

WEB_SEARCH_PROVIDER=
WEB_SEARCH_MAX_RESULTS=5
TAVILY_API_KEY=

N8N_ENABLED=false
N8N_HOST=localhost
N8N_PORT=5678
N8N_WEBHOOK_BASE_URL=http://localhost:5678/webhook
N8N_WEBHOOK_SECRET=change-this-n8n-secret
N8N_EVENT_MAX_RETRIES=2
N8N_EVENT_RETRY_BACKOFF_SECONDS=1

ADMIN_USERNAME=admin
ADMIN_PASSWORD=Admin123!
ADMIN_DISPLAY_NAME=System Admin

PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
PIP_EXTRA_INDEX_URL=https://pypi.org/simple
PIP_TRUSTED_HOST=pypi.tuna.tsinghua.edu.cn pypi.org files.pythonhosted.org

BACKEND_PORT=8080
CLOUD_PORT=8081
UI_PORT=5173
NGINX_HTTP_PORT=8088
