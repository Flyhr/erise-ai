COMPOSE_PROJECT_NAME=erise-ai

MYSQL_DATABASE=erise_ai
MYSQL_USER=erise
MYSQL_PASSWORD=erise_password
MYSQL_ROOT_PASSWORD=root_password
MYSQL_HOST_PORT=3306

REDIS_PASSWORD=redis_password
REDIS_HOST_PORT=6379

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_BUCKET=erise-ai
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

JWT_SECRET=please-change-this-jwt-secret-at-least-32-chars
INTERNAL_API_KEY=please-change-this-internal-api-key-to-a-long-random-value
N8N_ENABLED=false
N8N_WEBHOOK_BASE_URL=http://localhost:5678/webhook
N8N_WEBHOOK_SECRET=change-this-n8n-secret
N8N_EVENT_MAX_RETRIES=2
N8N_EVENT_RETRY_BACKOFF_SECONDS=1

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat
OLLAMA_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_CHAT_MODEL=qwen2.5:7b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
VLLM_API_KEY=
VLLM_BASE_URL=http://localhost:8000/v1
# AiAssistant registers and requests this code when MODEL_PROVIDER=VLLM.
VLLM_MODEL_CODE=Qwen/Qwen2.5-7B-Instruct
VLLM_MODEL=Qwen/Qwen2.5-7B-Instruct
VLLM_SERVED_MODEL_NAME=Qwen/Qwen2.5-7B-Instruct
VLLM_EMBED_MODEL=BAAI/bge-m3
VLLM_EMBED_SERVED_MODEL_NAME=text-embedding-3-small
VLLM_IMAGE_TAG=v0.8.5
VLLM_CUDA_VISIBLE_DEVICES=0
VLLM_EMBED_CUDA_VISIBLE_DEVICES=1
VLLM_NVIDIA_VISIBLE_DEVICES=all
VLLM_EMBED_NVIDIA_VISIBLE_DEVICES=all
VLLM_SHM_SIZE=16gb
VLLM_EMBED_SHM_SIZE=8gb
VLLM_TENSOR_PARALLEL_SIZE=1
VLLM_MAX_MODEL_LEN=32768
VLLM_MAX_NUM_SEQS=16
VLLM_GPU_MEMORY_UTILIZATION=0.90
VLLM_EMBED_MAX_MODEL_LEN=8192
VLLM_EMBED_GPU_MEMORY_UTILIZATION=0.85
LITELLM_API_KEY=
LITELLM_BASE_URL=http://localhost:4000/v1
LITELLM_MODEL=deepseek/deepseek-chat
MODEL_PROVIDER=
MODEL_BASE_URL=
MODEL_API_KEY=
DEFAULT_MODEL_CODE=deepseek-chat

# If you deploy with the vLLM overlay, also copy deploy/vllm/vllm.env.example
# and keep DEFAULT_MODEL_CODE aligned with VLLM_MODEL_CODE.

ADMIN_USERNAME=admin
ADMIN_PASSWORD=Admin123!
ADMIN_DISPLAY_NAME=System Admin

BACKEND_PORT=8080
CLOUD_PORT=8081
UI_PORT=5173
NGINX_HTTP_PORT=8088
