# Overlay mode:
# docker compose -f docker-compose.yml -f deploy/vllm/docker-compose.prod.yml --env-file .env --env-file deploy/vllm/vllm.env.example --profile vllm up -d

# Provider routing
MODEL_PROVIDER=VLLM
MODEL_BASE_URL=http://vllm:8000/v1
MODEL_API_KEY=
VLLM_BASE_URL=http://vllm:8000/v1
VLLM_API_KEY=
EMBEDDING_PROVIDER_CODE=VLLM
EMBED_BASE_URL=http://vllm-embed:8001/v1

# Keep AiAssistant / DB default model code stable by aliasing the served model name.
# If current default_model_code is deepseek-chat, keep VLLM_SERVED_MODEL_NAME=deepseek-chat.
DEFAULT_MODEL_CODE=deepseek-chat
VLLM_MODEL=Qwen/Qwen2.5-7B-Instruct
VLLM_SERVED_MODEL_NAME=deepseek-chat

# Embedding model alias. Keep this aligned with EMBEDDING_MODEL used by AiAssistant.
EMBEDDING_MODEL=text-embedding-3-small
VLLM_EMBED_MODEL=BAAI/bge-m3
VLLM_EMBED_SERVED_MODEL_NAME=text-embedding-3-small

# Runtime / GPU
VLLM_IMAGE_TAG=v0.8.5
HUGGING_FACE_HUB_TOKEN=
VLLM_CUDA_VISIBLE_DEVICES=0
VLLM_EMBED_CUDA_VISIBLE_DEVICES=1
VLLM_NVIDIA_VISIBLE_DEVICES=all
VLLM_EMBED_NVIDIA_VISIBLE_DEVICES=all
VLLM_SHM_SIZE=16gb
VLLM_EMBED_SHM_SIZE=8gb
VLLM_TENSOR_PARALLEL_SIZE=1
VLLM_MAX_MODEL_LEN=32768
VLLM_MAX_NUM_SEQS=16
VLLM_GPU_MEMORY_UTILIZATION=0.90
VLLM_EMBED_MAX_MODEL_LEN=8192
VLLM_EMBED_GPU_MEMORY_UTILIZATION=0.85
