# Unified LiteLLM production gateway defaults.
# Official production gateway command:
# docker compose -f docker-compose.yml -f deploy/litellm/docker-compose.prod.yml --env-file .env --env-file deploy/litellm/litellm.env.example --profile litellm up -d
#
# LiteLLM becomes the only AI endpoint that cloud talks to. DeepSeek is the
# default chat route, local Ollama exposes qwen3:1.7b, and OpenAI remains
# available through the same gateway.

MODEL_PROVIDER=LITELLM
MODEL_BASE_URL=http://litellm:4000/v1
LITELLM_API_KEY=
LITELLM_BASE_URL=http://litellm:4000/v1
LITELLM_MODEL=deepseek-chat
DEFAULT_MODEL_CODE=deepseek-chat
OLLAMA_HOST_PORT=11434
OLLAMA_CHAT_MODEL=qwen3:1.7b
OPENAI_BASE_URL=https://api.openai.com/v1
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
EMBEDDING_PROVIDER_CODE=LITELLM
EMBED_BASE_URL=http://litellm:4000/v1
EMBEDDING_MODEL=text-embedding-3-small

# Put all secrets in the root .env file.
# Do not redefine OPENAI_API_KEY / DEEPSEEK_API_KEY / MODEL_API_KEY /
# LITELLM_API_KEY in this overlay env file, or they may override .env
# values when both --env-file arguments are used together.
