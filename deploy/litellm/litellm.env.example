# Development gateway overlay on top of docker-compose.dev.yml
# docker compose --env-file .env.dev -f docker-compose.dev.yml -f deploy/litellm/docker-compose.dev.yml up --build

MODEL_PROVIDER=LITELLM
MODEL_BASE_URL=http://litellm:4000/v1
MODEL_API_KEY=
LITELLM_API_KEY=
LITELLM_BASE_URL=http://litellm:4000/v1
DEFAULT_MODEL_CODE=qwen2.5:7b
EMBEDDING_PROVIDER_CODE=LITELLM
EMBED_BASE_URL=http://litellm:4000/v1
EMBEDDING_MODEL=text-embedding-3-small

# Production overlay on top of docker-compose.yml + deploy/vllm/docker-compose.prod.yml
# docker compose -f docker-compose.yml -f deploy/vllm/docker-compose.prod.yml -f deploy/litellm/docker-compose.vllm.yml --env-file .env --env-file deploy/vllm/vllm.env.example --env-file deploy/litellm/litellm.env.example --profile vllm --profile litellm up -d
