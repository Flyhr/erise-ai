{
  "name": "Erise Notification Fanout",
  "nodes": [
    {
      "parameters": {
        "path": "notification-fanout",
        "httpMethod": "POST",
        "responseMode": "lastNode"
      },
      "id": "NotificationWebhook",
      "name": "Notification Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [260, 260]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://host.docker.internal:8080/api/v1/automation/webhooks/notifications",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "X-N8N-Webhook-Secret",
              "value": "={{$env.N8N_WEBHOOK_SECRET}}"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ { requestId: $json.body.requestId || $execution.id, workflowCode: 'notification-fanout', eventType: $json.body.eventType || 'notification.manual', title: $json.body.title || 'Erise 通知', content: $json.body.content || '请查看详情。', notificationType: $json.body.notificationType || 'N8N_EVENT', sendToAll: $json.body.sendToAll ?? false, userIds: $json.body.userIds || [] } }}"
      },
      "id": "NotificationForward",
      "name": "Notification Forward",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [620, 260]
    }
  ],
  "connections": {
    "Notification Webhook": {
      "main": [
        [
          {
            "node": "Notification Forward",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  }
}
