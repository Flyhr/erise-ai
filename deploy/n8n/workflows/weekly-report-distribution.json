{
  "name": "Erise Weekly Report Distribution",
  "nodes": [
    {
      "parameters": {
        "path": "weekly-report-created",
        "httpMethod": "POST",
        "responseMode": "lastNode"
      },
      "id": "WeeklyReportWebhook",
      "name": "Weekly Report Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [260, 260]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://host.docker.internal:8080/api/v1/automation/webhooks/notifications",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "X-N8N-Webhook-Secret",
              "value": "={{$env.N8N_WEBHOOK_SECRET}}"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ { requestId: $json.body.requestId, workflowCode: 'weekly-report-distribution', eventType: 'weekly_report.created', title: '项目周报草稿已生成', content: '项目 #' + $json.body.projectId + ' 的周报草稿《' + $json.body.title + '》已生成。', notificationType: 'N8N_EVENT', sendToAll: false, userIds: [$json.body.userId] } }}"
      },
      "id": "WeeklyNotify",
      "name": "Weekly Notify",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [620, 260]
    }
  ],
  "connections": {
    "Weekly Report Webhook": {
      "main": [
        [
          {
            "node": "Weekly Notify",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  }
}
